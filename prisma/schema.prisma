generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
  WAREHOUSE_STAFF
  DRIVER
  DISPATCHER
  FINANCE_OFFICER
  MARKETING
  FRONT_DESK
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ShipmentType {
  DOMESTIC
  INTERNATIONAL
  EXPRESS
  STANDARD
  FREIGHT
  BULK_CARGO
}

enum ShipmentStatus {
  DRAFT
  SCHEDULED
  PICKED_UP
  IN_TRANSIT
  ARRIVED_AT_HUB
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
  RETURNED
}

enum InventoryCategory {
  PACKAGING_MATERIALS
  GOODS
  SPARE_PARTS
  RETURNED_ITEMS
  WAREHOUSE_SUPPLIES
}

enum InventoryOperation {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
  CYCLE_COUNT
}

enum VehicleType {
  MOTORCYCLE
  VAN
  TRUCK
  CONTAINER_TRUCK
  CARGO_VEHICLE
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

enum DriverStatus {
  AVAILABLE
  ON_DUTY
  OFF_DUTY
  SUSPENDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT_CARD
  CASH
  CHEQUE
  MOBILE_MONEY
}

enum TicketCategory {
  SHIPMENT_DELAY
  DAMAGED_GOODS
  LOST_SHIPMENT
  BILLING_ISSUE
  GENERAL_INQUIRY
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
}

enum NotificationType {
  SHIPMENT_CREATED
  SHIPMENT_STATUS_CHANGED
  SHIPMENT_DELIVERED
  CUSTOMER_CREATED
  INVOICE_GENERATED
  PAYMENT_RECEIVED
  SYSTEM
}

model User {
  id            String     @id @default(cuid())
  firstName     String
  lastName      String
  email         String     @unique
  passwordHash  String
  role          UserRole
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  customer      Customer?
  driver        Driver?
  managedWarehouses Warehouse[] @relation("WarehouseManager")
  warehouseAssignments WarehouseAssignment[]
  auditLogs     AuditLog[]
  supportTickets SupportTicket[] @relation("TicketCreator")
  assignedTickets SupportTicket[] @relation("TicketAssignee")
  notifications Notification[]
  dispatchedShipments Shipment[] @relation("ShipmentDispatcher")
}

model Customer {
  id            String   @id @default(cuid())
  userId        String   @unique
  companyName   String
  contactPerson String
  phone         String
  address       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipments     Shipment[]
  invoices      Invoice[]
  addresses     Address[]
  supportTickets SupportTicket[]
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  label      String
  street     String
  city       String
  state      String
  postalCode String
  country    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Shipment {
  id              String         @id @default(cuid())
  trackingNumber  String         @unique
  customerId      String
  shipmentType    ShipmentType
  weight          Float
  lengthCm        Float?
  widthCm         Float?
  heightCm        Float?
  packageCount    Int            @default(1)
  cbm             Float?
  origin          String
  destination     String
  status          ShipmentStatus @default(DRAFT)
  driverId        String?
  vehicleId       String?
  dispatcherId    String?
  warehouseId     String?
  scheduledPickup DateTime?
  estimatedDelivery DateTime?
  actualDelivery  DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  customer        Customer       @relation(fields: [customerId], references: [id])
  driver          Driver?        @relation(fields: [driverId], references: [id])
  vehicle         Vehicle?       @relation(fields: [vehicleId], references: [id])
  dispatcher      User?          @relation("ShipmentDispatcher", fields: [dispatcherId], references: [id])
  warehouse       Warehouse?     @relation(fields: [warehouseId], references: [id])
  events          ShipmentEvent[]
  trackingUpdates TrackingUpdate[]
  invoices        Invoice[]
}

model ShipmentEvent {
  id         String         @id @default(cuid())
  shipmentId String
  eventType  ShipmentStatus
  location   String
  notes      String?
  timestamp  DateTime       @default(now())

  shipment   Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model TrackingUpdate {
  id         String   @id @default(cuid())
  shipmentId String
  latitude   Float
  longitude  Float
  location   String
  timestamp  DateTime @default(now())

  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique @default("WH-TEMP")
  name      String
  address   String
  city      String?
  phone     String?
  isActive  Boolean  @default(true)
  managerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manager     User?                  @relation("WarehouseManager", fields: [managerId], references: [id])
  assignments WarehouseAssignment[]
  zones       Zone[]
  inventory   InventoryItem[]
  shipments   Shipment[]
}

model WarehouseAssignment {
  id          String   @id @default(cuid())
  userId      String
  warehouseId String
  isManager   Boolean  @default(false)
  assignedAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([userId, warehouseId])
  @@index([warehouseId])
  @@index([userId])
}

model Zone {
  id          String @id @default(cuid())
  warehouseId String
  name        String
  code        String

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  racks       Rack[]
}

model Rack {
  id     String @id @default(cuid())
  zoneId String
  name   String
  code   String

  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  shelves Shelf[]
}

model Shelf {
  id     String @id @default(cuid())
  rackId String
  name   String
  code   String

  rack   Rack   @relation(fields: [rackId], references: [id], onDelete: Cascade)
  bins   Bin[]
}

model Bin {
  id      String @id @default(cuid())
  shelfId String
  name    String
  code    String

  shelf   Shelf  @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  inventory InventoryItem[]
}

model InventoryItem {
  id          String            @id @default(cuid())
  warehouseId String
  binId       String?
  sku         String
  productName String
  category    InventoryCategory
  quantity    Int               @default(0)
  unitCost    Float             @default(0)
  reorderLevel Int              @default(10)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id])
  bin         Bin?              @relation(fields: [binId], references: [id])
  movements   InventoryMovement[]

  @@unique([warehouseId, sku])
}

model InventoryMovement {
  id          String             @id @default(cuid())
  inventoryId String
  operation   InventoryOperation
  quantity    Int
  notes       String?
  createdAt   DateTime           @default(now())

  inventory   InventoryItem      @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id              String        @id @default(cuid())
  plateNumber     String        @unique
  type            VehicleType
  capacity        Float
  status          VehicleStatus @default(AVAILABLE)
  fuelUsage       Float         @default(0)
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  drivers         Driver[]
  shipments       Shipment[]
}

model Driver {
  id            String       @id @default(cuid())
  userId        String       @unique
  licenseNumber String       @unique
  status        DriverStatus @default(AVAILABLE)
  vehicleId     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle       Vehicle?     @relation(fields: [vehicleId], references: [id])
  shipments     Shipment[]
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  customerId    String
  shipmentId    String?
  serviceType   String
  amount        Float
  tax           Float         @default(0)
  totalAmount   Float
  dueDate       DateTime
  status        InvoiceStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer      Customer      @relation(fields: [customerId], references: [id])
  shipment      Shipment?     @relation(fields: [shipmentId], references: [id])
  payments      Payment[]
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  paymentMethod PaymentMethod
  amount        Float
  paymentDate   DateTime      @default(now())
  reference     String?
  createdAt     DateTime      @default(now())

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id          String         @id @default(cuid())
  customerId  String
  createdById String
  assigneeId  String?
  category    TicketCategory
  status      TicketStatus   @default(OPEN)
  subject     String
  description String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  customer    Customer       @relation(fields: [customerId], references: [id])
  createdBy   User           @relation("TicketCreator", fields: [createdById], references: [id])
  assignee    User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entity     String
  entityId   String
  details    String?
  createdAt  DateTime    @default(now())

  user       User?       @relation(fields: [userId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}
